# Google AI Studio (Gemini) API Key — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# 使用するGeminiモデル (任意。未指定なら gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Google Cloud credentials (JSON string of service account key)
# Vercel環境変数にはJSONを1行にして貼り付けてください
# BigQueryに接続する場合のみ必要です。CSVアップロードだけを使う場合は不要です。
GOOGLE_CLOUD_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
